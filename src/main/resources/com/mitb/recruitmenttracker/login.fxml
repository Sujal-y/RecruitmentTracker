<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<TabPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.mitb.recruitmenttracker.LoginController"
         tabClosingPolicy="UNAVAILABLE" prefWidth="480" prefHeight="420" styleClass="main-view">
    <Tab text="Administrator">
        <VBox spacing="14" styleClass="card-container">
            <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>
            <Label text="Administrator sign-in" styleClass="header-label"/>
            <Label text="Sign in to manage applicants and interview stages." wrapText="true"
                   styleClass="text-muted"/>
            <Label text="Username" styleClass="subheader-label"/>
            <TextField fx:id="adminUserField" promptText="Username" maxWidth="320"/>
            <Label text="Password" styleClass="subheader-label"/>
            <PasswordField fx:id="adminPassField" promptText="Password" maxWidth="320"/>
            <HBox spacing="10">
                <Button text="Sign in" defaultButton="true" onAction="#onAdminLogin"/>
            </HBox>
            <Label text="Default: admin / admin (override with ADMIN_USER and ADMIN_PASSWORD)."
                   wrapText="true" styleClass="text-small-muted"/>
        </VBox>
    </Tab>
    <Tab text="Applicant">
        <VBox spacing="14" styleClass="card-container">
            <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>
            <Label text="Apply for a position" styleClass="header-label"/>
            <Label text="Submit your details. An administrator will review your application."
                   wrapText="true" styleClass="text-muted"/>
            <Label text="Full name" styleClass="subheader-label"/>
            <TextField fx:id="applicantNameField" promptText="Your name" maxWidth="320"/>
            <Label text="Email" styleClass="subheader-label"/>
            <TextField fx:id="applicantEmailField" promptText="you@example.com" maxWidth="320"/>
            <HBox spacing="10">
                <Button text="Submit application" onAction="#onApplicantSubmit"/>
            </HBox>
        </VBox>
    </Tab>
</TabPane>
